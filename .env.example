# CFC Forecaster — production environment template.
# Copy to .env.prod and fill real values. NEVER commit .env / .env.prod (gitignored).
#   cp .env.example .env.prod
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# ── security (REQUIRED — boot aborts if missing/insecure in production) ──
APP_ENV=production
# strong random: python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=
AUTH_DISABLED=0
# comma-separated public origins allowed by CORS
ALLOWED_ORIGINS=https://cfc.cityholdings.com.mm

# ── login accounts (REQUIRED for the login page) ──
# Superadmin (role=admin). Plaintext by design; keep .env.prod out of git.
SUPERADMIN_EMAIL=admin@cityfood.com
SUPERADMIN_PASSWORD=
# optional extra users: "email:password:role,email:password:role"  role ∈ viewer|ops|finance|admin
AUTH_USERS=
# session length in days (default 1); "remember me" uses REMEMBER_DAYS (default 30)
SESSION_DAYS=1
REMEMBER_DAYS=30

# ── SSO / OIDC (Keycloak) — optional; email login still works when off ──
# Register a confidential client in Keycloak with redirect URI = <ORIGIN>/api/auth/sso/callback
OIDC_ENABLED=0
OIDC_PROVIDER_NAME=Keycloak
OIDC_ISSUER=https://iam.example.com/realms/city-group
OIDC_CLIENT_ID=city-agent-rise
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://rise.example.com/api/auth/sso/callback
OIDC_SCOPES=openid email profile
# group/role → app role mapping (Keycloak group or realm-role names)
OIDC_ROLE_CLAIM=groups
OIDC_ADMIN_GROUP=rise-admin
OIDC_OPS_GROUP=rise-ops
OIDC_FINANCE_GROUP=rise-finance
OIDC_DEFAULT_ROLE=viewer

# ── in-container training memory guard ──
# CFC_TRAIN_LEAN=1 caps rows + uses lighter LightGBM (400 trees / 63 leaves) so the local
# Training lane doesn't OOM (exit -9). Heavy full-fidelity training runs on Fabric. 0 = full.
CFC_TRAIN_LEAN=1
CFC_MAX_ROWS=1500000
# public https URL of the web app (adapter-node CSRF check)
ORIGIN=https://cfc.cityholdings.com.mm
# domain Caddy serves TLS for; 'localhost' = HTTP only (no cert)
DOMAIN=cfc.cityholdings.com.mm

# ── Microsoft Fabric (ONLY needed if live sync is enabled) ──
# read-only; rotate FABRIC_PASSWORD regularly
FABRIC_SERVER=
FABRIC_DATABASE=HUB_REPORTING_DB
FABRIC_SCHEMA=edm
FABRIC_USER=
FABRIC_PASSWORD=

# ── LLM narration (OPTIONAL — Autopilot works without it) ──
# OpenRouter ONLY. Never a direct Google/OpenAI/Anthropic key.
OPENROUTER_API_KEY=
AGENT_MODEL=anthropic/claude-3.5-haiku

# ── host ports (optional overrides) ──
HTTP_PORT=80
HTTPS_PORT=443

# --- Fabric SQL read layer (Phase 3) — set USE_FABRIC=1 to read cfc_* from Lakehouse ---
USE_FABRIC=0
FABRIC_SQL_ENDPOINT=<lakehouse>.datawarehouse.fabric.microsoft.com
FABRIC_SQL_DB=LK_CFC_Sales
FABRIC_SCHEMA=dbo
FABRIC_USER=you@tenant.com
FABRIC_PASSWORD=
FABRIC_TENANT_ID=

# --- Fabric notebook trigger (Phase 2) — run experiment / approve-promote from the app ---
FABRIC_WORKSPACE_ID=<hub-ai workspace guid>
FABRIC_NOTEBOOK_ID=<CFC_ML_Pipeline notebook guid>
